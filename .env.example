# API Configuration
# For demo mode, leave these empty - mock data will be used automatically

# Claude API (for Bull/Bear analysis)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Knowledge Base API (optional - for production use)
KB_API_BASE_URL=https://your-kb-api.example.com/api/v1/
KB_USERNAME=your_username
KB_PASSWORD=your_password

# Demo Mode
# Set to "true" to force mock data (default: auto-detect)
DEMO_MODE=true
