# API Configuration
# For demo mode, leave these empty - mock data will be used automatically
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!

# LLM API (for Bull/Bear analysis)
# Supports OpenAI-compatible API endpoints
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Knowledge Base API (optional - for production use)
# Credentials are ONLY read from environment variables, never hardcoded
KB_API_BASE_URL=https://your-kb-api.example.com/api/v1/
KB_API_USERNAME=your_username
KB_API_PASSWORD=your_password

# Demo Mode
# Set to "true" to force mock data (default: auto-detect based on API config)
DEMO_MODE=true
